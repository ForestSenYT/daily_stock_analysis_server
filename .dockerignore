# ===================================
# Docker / Cloud Run 构建上下文过滤
# ===================================

# 版本控制 / CI
.git
.gitignore
.gitattributes
.github

# Python 缓存与字节码
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
.cache

# 虚拟环境
venv/
.venv/
env/
.env
.env.*
# 保留示例文件，方便部署时参考
!.env.example

# 编辑器 / IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# 前端构建产物（Cloud Run 容器内不需要 node_modules / 源码）
node_modules/
apps/*/node_modules/
apps/*/dist/
apps/*/.cache/
dist/
build/

# 运行时产物（容器内会重新生成）
reports/
logs/
data/cache/
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# 测试输出
.pytest_cache/
.coverage
htmlcov/

# 文档（按需保留 README）
*.md
!README.md
!docs/cloud-run-deploy.md

# 临时
tmp/
*.log
